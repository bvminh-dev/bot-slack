{
  "name": "tieu-nhi",
  "version": "0.1.0",
  "description": "Slack bot review PR Azure DevOps (i-001)",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node --env-file=.env dist/index.js",
    "dev": "node --env-file=.env -r ts-node/register src/index.ts",
    "test": "npm run build && node --test dist/__tests__",
    "test:unit": "npm run build && node --test dist/__tests__/pure.test.js dist/__tests__/context.test.js dist/__tests__/unit-extra.test.js",
    "test:func": "npm run build && node --test dist/__tests__/functional.test.js",
    "test:e2e": "npm --prefix web-admin run test:e2e"
  },
  "dependencies": {
    "@slack/bolt": "^3.18.0",
    "azure-devops-node-api": "^13.0.0",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.5.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.0",
    "@types/supertest": "^7.2.0",
    "mongodb-memory-server": "^11.2.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
