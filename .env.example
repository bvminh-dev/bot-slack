# --- tieu-nhi (i-001) ENV mẫu ---
# KHÔNG commit .env thật. Master key bảo vệ nghiêm ngặt (chỉ process đọc).

# HTTP
PORT=3000
ADMIN_UI_ORIGIN=http://localhost:5173

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=tieu_nhi

# Secret-at-rest (T3): master key 32 byte, base64. Sinh: openssl rand -base64 32
SECRET_MASTER_KEY=
SECRET_KEY_VERSION=1

# Session JWT (T4)
JWT_SECRET=
JWT_EXPIRES_IN=2h

# Slack (T10/T15)
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=

# Azure DevOps base (T8) — host cho phép (chống SSRF)
AZURE_ALLOWED_HOSTS=dev.azure.com,visualstudio.com
# Org dùng để xác thực PAT lúc login (connectionData → authenticatedUser). Vd: torus-engineering
AZURE_DEFAULT_ORG=

# Claude Code CLI (T9)
CLAUDE_CLI_BIN=claude
SKILLS_DIR=.claude/skills
SKILL_RUN_TIMEOUT_MS=600000

# Giới hạn an toàn (T13/T15) — frd #6
MAX_FILES_PER_PR=50
MAX_DIFF_LINES=5000
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_MS=600000

# Worker (T12/T14)
WORKER_CONCURRENCY=5
QUEUE_POLL_INTERVAL_MS=1500
JOB_LEASE_MS=900000
MAX_ATTEMPTS=3
RETRY_BACKOFF_MS=30000
